# {{ ansible_managed }}
[Unit]
Description=labctl broker daemon (classroom Docker Compose lab)
After=docker.service
Requires=docker.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 {{ labctl_opt_dir }}/labctld
Restart=on-failure
RestartSec=2
# Hardening (the daemon still needs the Docker socket, /srv/classroom and the
# audit log, so filesystem protection is deliberately limited).
NoNewPrivileges=true
ProtectKernelTunables=true
ProtectControlGroups=false
ProtectHome=true

[Install]
WantedBy=multi-user.target
