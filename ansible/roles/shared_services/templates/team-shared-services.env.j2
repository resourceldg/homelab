{% set team = item.item.name %}
{% set tid = team | replace('-', '_') %}
{% set pgpass = item.content | b64decode %}
{% set mqttpass = team_mqttpass.results[team_index].content | b64decode %}
# {{ ansible_managed }}
# Credenciales de servicios compartidos para el {{ team }}.
# Estos hostnames resuelven dentro de la red de tu proyecto (labctl los conecta).

# --- PostgreSQL (base de datos propia del equipo) ---
PGHOST=postgres
PGPORT=5432
PGDATABASE=db_{{ tid }}
PGUSER={{ tid }}
PGPASSWORD={{ pgpass }}
DATABASE_URL=postgresql://{{ tid }}:{{ pgpass }}@postgres:5432/db_{{ tid }}

# --- Redis (base lógica propia del equipo) ---
REDIS_URL=redis://redis:6379/{{ team_index + 1 }}

# --- Mailpit (SMTP de prueba, sin autenticación) ---
SMTP_HOST=mailpit
SMTP_PORT=1025

# --- MQTT (broker Mosquitto de tu propio proyecto) ---
# El broker viene ANÓNIMO por defecto (se accede por túnel SSH en loopback).
# Estas credenciales quedan listas por si activás autenticación en tu Mosquitto
# (ver el ejemplo nodered-mqtt del handbook). El host `mosquitto` es tu contenedor.
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USER={{ tid }}
MQTT_PASSWORD={{ mqttpass }}
