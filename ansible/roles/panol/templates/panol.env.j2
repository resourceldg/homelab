# {{ ansible_managed }}
# Entorno del stack panol. Lo lee Docker Compose (interpolación) y también se
# inyecta en los contenedores vía `env_file`.

# --- Puertos publicados en el host ---------------------------------------
PANOL_MQTT_BIND={{ panol_mqtt_bind }}
PANOL_MQTT_PORT={{ panol_mqtt_port }}
PANOL_MQTT_WS_PORT={{ panol_mqtt_ws_port }}
PANOL_PG_PORT={{ panol_pg_port }}
PANOL_NODERED_PORT={{ panol_nodered_port }}

# --- Base de auditoría ----------------------------------------------------
PANOL_DB_NAME={{ panol_db_name }}
PANOL_DB_USER={{ panol_db_user }}
PANOL_DB_PASSWORD={{ panol_db_password }}

# --- Identidad del servidor en el broker ----------------------------------
# La usa el healthcheck de mosquitto (y la comparten api y puente).
PANOL_MQTT_SERVER_USER={{ panol_mqtt_server_user }}
PANOL_MQTT_SERVER_PASSWORD={{ panol_mqtt_passwords[panol_mqtt_server_user] }}

TZ={{ server_timezone }}
