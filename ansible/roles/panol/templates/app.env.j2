# {{ ansible_managed }}
# Credenciales para el "cerebro" del pañol (api + puente MQTT, repo panol-iot).
# Cargalo con `env_file: /etc/panol/app.env` desde el compose de la app, con la
# app unida a la red externa `panol`. Los hostnames de abajo resuelven ahí.
#
# Legible por root y por el grupo {{ admin_user }}; NO lo copies al repo.

# --- Base de auditoría ----------------------------------------------------
PANOL_DSN=postgresql://{{ panol_db_user }}:{{ panol_db_password }}@postgres:5432/{{ panol_db_name }}

# --- Broker MQTT ----------------------------------------------------------
# El broker NO es anónimo (ver mosquitto.conf): el cliente tiene que llamar a
# username_pw_set() con estas credenciales antes de conectar.
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USER={{ panol_mqtt_server_user }}
MQTT_PASSWORD={{ panol_mqtt_passwords[panol_mqtt_server_user] }}
MQTT_CLIENT_ID=panol-puente

{% if panol_ematp_url | length > 0 and panol_ematp_token_raw.content is defined %}
# --- EMATP (tickets) ------------------------------------------------------
# Cada alarma viaja como ticket. El despachador manda el lote pendiente en un
# solo pedido y reintenta con espera creciente si EMATP no responde.
EMATP_URL={{ panol_ematp_url }}
EMATP_TOKEN={{ panol_ematp_token_raw.content | b64decode | trim }}
{% endif %}

TZ={{ server_timezone }}
