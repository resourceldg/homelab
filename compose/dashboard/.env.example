# Rendered by Ansible at deploy time. This example is for manual runs.
# Homepage refuses requests whose Host header isn't listed here (anti-DNS-rebind).
HOMEPAGE_ALLOWED_HOSTS=myhomelab.duckdns.org
# Substituted into config/*.yaml as {{HOMEPAGE_VAR_BASE_DOMAIN}}.
HOMEPAGE_VAR_BASE_DOMAIN=myhomelab.duckdns.org
