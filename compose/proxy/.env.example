# Rendered by Ansible from vault at deploy time. This example is for manual runs.
CADDY_BASE_DOMAIN=myhomelab.duckdns.org
ACME_EMAIL=you@example.com
DUCKDNS_TOKEN=replace-with-duckdns-token
# Networks allowed to reach the private Caddy sites (Prometheus, cAdvisor).
TAILSCALE_CIDR=100.64.0.0/10
LAN_CIDR=192.168.1.0/24
