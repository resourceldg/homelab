# Secrets — never commit decrypted material (per-environment vaults)
ansible/inventories/*/group_vars/all/vault.yml
!ansible/inventories/*/group_vars/all/vault.yml.example
*.pem
*.key
id_ed25519*
.env
!.env.example
compose/**/.env

# Vault password file
.vault_pass
.vault_pass.txt

# Ansible runtime
*.retry
ansible/.facts_cache/
__pycache__/
*.pyc
.pytest_cache/

# Editor
.idea/
.vscode/
*.swp
.venv/

# MkDocs build output
site/

# Local Claude Code settings (per-machine, not shared)
.claude/
